            if (filteredTerms.length > 0) {
                filteredTerms.forEach(kt => {
                    const termCard = document.createElement('div');
                    termCard.className = "bg-white dark:bg-slate-900 p-3 rounded-lg border border-slate-150 dark:border-slate-850 shadow-sm";
                    termCard.innerHTML = `<h6 class="text-xs font-bold text-slate-850 dark:text-white">${escapeHtml(kt.term)}</h6><p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1 leading-normal">${escapeHtml(kt.definition)}</p>`;
                    termsGrid.appendChild(termCard);
                });
            } else {
                termsGrid.innerHTML = `
                    <div class="bg-white dark:bg-slate-900 p-3 rounded-lg border border-slate-150 dark:border-slate-850 shadow-sm">
                        <h6 class="text-xs font-bold text-slate-850 dark:text-white">Core Term A</h6>
                        <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1 leading-normal">System term definitions automatically generated within standard prompt output arrays.</p>
                    </div>
                `;
            }

            // Update Quiz Component
            const quizSection = document.getElementById('preview-quiz-section');
            if (hasQuiz) {
                quizSection.classList.remove('hidden');
                document.getElementById('quiz-question-counter').innerText = `${quizCount} Question Simulator`;
                
                // Build dynamic simulated questions based on count
                const questionsSandbox = document.getElementById('quiz-questions-sandbox');
                questionsSandbox.innerHTML = '';
                
                // Static bank of highly optimized sample interactive questions
                const qBank = [
                    {
                        q: "Which specific cell structure acts as the factory site where photosynthesis takes place?",
                        options: ["Mitochondria", "Chloroplast", "Nucleus", "Ribosome"],
                        correct: 1,
                        expl: "Chloroplasts contain the green pigment chlorophyll which actively captures sunlight."
                    },
                    {
                        q: "What is the primary organic product generated by plants during light conversion cycles?",
                        options: ["Carbon Dioxide", "Water Vapor", "Glucose (Sugar)", "Nitrogen Gas"],
                        correct: 2,
                        expl: "Glucose serves as the vital chemical energy source for both plant structure and animals."
                    },
                    {
                        q: "What raw atmospheric input enters the plant leaf cells through stomata pores?",
                        options: ["Pure Oxygen", "Carbon Dioxide", "Liquid Water", "Argon Gas"],
                        correct: 1,
                        expl: "Stomata are the gatekeepers on the bottom of plant leaves absorbing carbon dioxide from the air."
                    },
                    {
                        q: "In our core solar panel analogy, what physical plant substance acts like the PV silicon capture grids?",
                        options: ["The Roots", "The Stem Cells", "Chlorophyll Pigments", "Glucose Crystals"],
                        correct: 2,
                        expl: "Chlorophyll is the specific active pigment that captures photons and utilizes light energy."
                    },
                    {
                        q: "Why is photosynthesis considered an essential thermodynamic bridge for animal life?",
                        options: ["It produces nitrogen", "It cools the global atmosphere by 10 degrees", "It produces oxygen and glucose needed for respiration", "It eliminates sunlight pollution"],
                        correct: 2,
                        expl: "Oxygen and glucose are the primary input requirements for aerobic cellular respiration in animals."
                    }
                ];

                // Render matching number of mock questions
                for (let i = 0; i < Math.min(quizCount, qBank.length); i++) {
                    const qItem = qBank[i];
                    const qContainer = document.createElement('div');
                    qContainer.className = "bg-white dark:bg-slate-900 p-3.5 rounded-lg border border-slate-150 dark:border-slate-850 space-y-2";
                    
                    let optionsHTML = '';
                    qItem.options.forEach((opt, oIdx) => {
                        optionsHTML += `
                            <label class="flex items-center space-x-2.5 p-2 rounded-md hover:bg-slate-50 dark:hover:bg-slate-800/50 cursor-pointer transition text-xs text-slate-700 dark:text-slate-300">
                                <input type="radio" name="sandbox-q-${i}" value="${oIdx}" class="w-3.5 h-3.5 text-emerald-600 border-slate-300 focus:ring-emerald-500">
                                <span>${opt}</span>
                            </label>
                        `;
                    });

                    qContainer.innerHTML = `
                        <h6 class="text-xs font-bold text-slate-800 dark:text-slate-200">Q${i+1}: ${qItem.q}</h6>
                        <div class="space-y-1">${optionsHTML}</div>
                    `;
                    questionsSandbox.appendChild(qContainer);
                }
                
                // Reset feedback state
                document.getElementById('quiz-sandbox-feedback').classList.add('hidden');
                document.getElementById('btn-submit-quiz').classList.remove('hidden');

            } else {
                quizSection.classList.add('hidden');
            }
        }

        // Validate the answers in the interactive sandbox quiz
        function checkSandboxQuiz() {
            const hasQuiz = document.getElementById('generate-quiz').checked;
            if (!hasQuiz) return;

            const quizCount = parseInt(document.getElementById('quiz-count').value);
            const qBankAnswers = [1, 2, 1, 2, 2]; // Hardcoded correct index indicators
            let correctCount = 0;
            let totalAnswered = 0;

            for (let i = 0; i < Math.min(quizCount, qBankAnswers.length); i++) {
                const selectedOption = document.querySelector(`input[name="sandbox-q-${i}"]:checked`);
                if (selectedOption) {
                    totalAnswered++;
                    if (parseInt(selectedOption.value) === qBankAnswers[i]) {
                        correctCount++;
                    }
                }
            }

            const feedback = document.getElementById('quiz-sandbox-feedback');
            feedback.classList.remove('hidden');
            
            if (totalAnswered < Math.min(quizCount, qBankAnswers.length)) {
                feedback.className = "p-3 bg-accent-amber/10 dark:bg-amber-950/40 text-accent-amber text-xs rounded-xl border border-accent-amber/20 text-center font-bold";
                feedback.innerText = `⚠️ You only answered ${totalAnswered} of ${Math.min(quizCount, qBankAnswers.length)} questions! Complete all answers to finalize.`;
            } else {
                const scorePercent = Math.round((correctCount / totalAnswered) * 100);
                if (scorePercent >= 80) {
                    feedback.className = "p-3 bg-emerald-100 dark:bg-emerald-950/40 text-emerald-800 dark:text-emerald-300 text-xs rounded-xl border border-emerald-200 dark:border-emerald-900/50 text-center font-bold";
                } else {
                    feedback.className = "p-3 bg-accent-rose/10 dark:bg-rose-950/40 text-accent-rose text-xs rounded-xl border border-accent-rose/20 text-center font-bold";
                }
                feedback.innerText = `📊 Score: ${correctCount} / ${totalAnswered} (${scorePercent}%) - Dynamic verification simulation successfully complete!`;
            }
        }

        // Clean text helper to prevent DOM breakage
        function escapeHtml(str) {
            return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }

        // Tab Navigation Module (Satisfies ARIA Role Tab Tracking)
        function switchTab(tabId) {
            const btnPrompt = document.getElementById('tab-prompt');
            const btnPreview = document.getElementById('tab-preview');
            const panelPrompt = document.getElementById('panel-prompt');
            const panelPreview = document.getElementById('panel-preview');

            if (tabId === 'prompt') {
                btnPrompt.className = "px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all focus:outline-none flex items-center gap-2 bg-white dark:bg-slate-800 shadow-sm text-primary-600 dark:text-white";
                btnPrompt.setAttribute('aria-selected', 'true');
                btnPreview.className = "px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all focus:outline-none flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800";
                btnPreview.setAttribute('aria-selected', 'false');

                panelPrompt.classList.remove('hidden');
                panelPrompt.classList.add('block');
                panelPreview.classList.add('hidden');
                panelPreview.classList.remove('block');
            } else {
                btnPreview.className = "px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all focus:outline-none flex items-center gap-2 bg-white dark:bg-slate-800 shadow-sm text-primary-600 dark:text-white";
                btnPreview.setAttribute('aria-selected', 'true');
                btnPrompt.className = "px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all focus:outline-none flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800";
                btnPrompt.setAttribute('aria-selected', 'false');

                panelPreview.classList.remove('hidden');
                panelPreview.classList.add('block');
                panelPrompt.classList.add('hidden');
                panelPrompt.classList.remove('block');
                
                // Re-verify layouts
                buildInteractiveMockSandbox();
            }
        }

        // Fallback Clipboard copy operation
        function copyPromptToClipboard() {
            const copyText = document.getElementById("prompt-output");
            copyText.select();
            copyText.setSelectionRange(0, 99999); // Mobile compatibility constraint

            try {
                // Execute standard execution command to guarantee performance within nested iFrames
                const success = document.execCommand('copy');
                if (success) {
                    showToast("Prompt copied to clipboard successfully!", "success");
                } else {
                    showToast("Failed to copy prompt automatically.", "error");
                }
            } catch (err) {
                // Fallback attempt
                navigator.clipboard.writeText(copyText.value)
                    .then(() => showToast("Prompt copied to clipboard!", "success"))
                    .catch(() => showToast("Please manually select and copy text.", "error"));
            }
        }

        // Toast Alert Manager
        function showToast(message, type = "success") {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            // Apply different accessibility color accents based on category
            const accentClass = type === "success" 
                ? "border-emerald-500 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100" 
                : "border-accent-rose bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100";
                
            const icon = type === "success"
                ? `<svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
                : `<svg class="w-5 h-5 text-accent-rose" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>`;

            toast.className = `flex items-center space-x-3 p-4 rounded-xl shadow-xl border-l-4 ${accentClass} pointer-events-auto transform translate-y-2 opacity-0 transition-all duration-300 max-w-sm mb-3`;
            toast.innerHTML = `
                <div class="flex-shrink-0">${icon}</div>
                <div class="text-xs font-bold leading-normal">${message}</div>
            `;

            container.appendChild(toast);

            // Animate In
            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 50);

            // Animate Out & Remove
            setTimeout(() => {
                toast.classList.add('translate-y-2', 'opacity-0');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 3500);
        }
    </script>
</body>
