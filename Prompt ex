                analogyTitle.innerHTML = '⚙️ Technical Framing: Industrial Solar Fuel Plants';
                analogyBody.innerText = "Consider an industrial facility designed to convert raw solar radiation directly into refined hydrogen fuel. The chloroplast represents the physical plant facility, while sunlight triggers chemical pathways that split gaseous atmospheric inputs into highly structured structural fuels.";
            } else if (analogyVal === 'historical-narrative') {
                analogyTitle.innerHTML = '📖 Historical Framing: Discovering the Invisible Air';
                analogyBody.innerText = "In the late 1700s, Jan Ingenhousz discovered that plants only purified carbon-filled 'bad air' when direct sunlight was actively hitting their leaves. This historical narrative details how we learned that plants are literally fueled by invisible components surrounding us.";
            } else {
                analogyTitle.innerHTML = '💡 Definition Focus: Direct Chemical Mechanics';
                analogyBody.innerText = "Plants execute a metabolic synthesis process converting radiant carbon molecules directly to dense sugars. This is a fundamental thermodynamic bridge sustaining biological life cycles.";
