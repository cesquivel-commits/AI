            document.getElementById('preview-tag-grade').innerText = `Target Cohort: ${grade}`;

            // Update Objectives
            const objList = document.getElementById('preview-list-objectives');
            objList.innerHTML = '';
            const filteredObjs = objectives.filter(o => o.trim() !== "");
