        // Preset Loader
        function loadPreset(key) {
            const data = PRESETS[key];
            if (!data) return;

            document.getElementById('lesson-title').value = data.title;
            document.getElementById('lesson-subject').value = data.subject;
            document.getElementById('lesson-grade').value = data.grade;
            document.getElementById('analogy-preference').value = data.analogy;
            document.getElementById('lesson-summary').value = data.summary;

            objectives = [...data.objectives];
            keyTerms = data.keyTerms.map(x => ({ ...x }));

            renderObjectivesInputs();
            renderKeyTermsInputs();
            generatePrompt();
            buildInteractiveMockSandbox();
            
            showToast(`Loaded ${data.title} Preset!`, "success");
        }

        // CORE ENGINE: Compiled Prompt Generator Generator
        function generatePrompt() {
            const title = document.getElementById('lesson-title').value || "[Lesson Title]";
            const subject = document.getElementById('lesson-subject').value || "[Lesson Subject]";
            const grade = document.getElementById('lesson-grade').value;
            const analogy = document.getElementById('analogy-preference').value;
            const summary = document.getElementById('lesson-summary').value || "[General focus specified by teacher]";
