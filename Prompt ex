            // Generate clean lists for the prompt injection
            const cleanObjList = objectives.filter(o => o.trim() !== "").map(o => `* SMART Objective: ${o}`).join("\n");
            const cleanTermsList = keyTerms.filter(kt => kt.term.trim() !== "").map(kt => `* "${kt.term}": ${kt.definition}`).join("\n");

            // Build Prompt Template
            let prompt = `You are an expert pedagogy designer, instructional engineer, and accessibility (ADA) strategist. Create a complete, high-structure, and pedagogically sound lesson plan optimized for:

COHORT / GRADE LEVEL: ${grade}
SUBJECT: ${subject}
LESSON TITLE: ${title}

---

### CORE OBJECTIVES & COMPLIANCE REQUIREMENTS
This lesson plan and all generated materials must adhere strictly to Universal Design for Learning (UDL) guidelines, satisfying both ADA compliance requirements and cognitive scaffolding:
1. Ensure a logical hierarchy (use standard markdown headers: #, ##, ###, and never skip levels).
2. Write with a high color-contrast readability layout and use explicit verbal cues.
3. Keep sentence structures clean, offering scaffolding details and simplified definitions where possible.
4. Integrate phonetic hints or conceptual links for complex terminology.

---

### REQUIRED CONTENT SECTIONS

1. **LESSON META-DATA**
   Provide a standard lesson overview aligning with targeted educational standards. Include the subject area, estimated lesson length, and required class materials.

2. **SMART LEARNING OBJECTIVES**
   Based on the following parameters, formulate clear, observable, and measurable milestones:
${cleanObjList || "* [Construct standard SMART learning objectives mapping to this domain]"}

3. **ANALOGY & REAL-WORLD ENGAGEMENT**
   Design a core introductory analogy tailored to the following tone/structure profile:
   * Preference Profile: ${analogy.replace('-', ' ')}
   * Context Focus: ${summary}
   Use this concept to anchor the lesson's main core challenge in concrete, observable everyday physics or social dynamics.

4. **KEY VOCABULARY MATRIX**
   Present these specific vocabulary terms and complete semantic explanations within a structural markdown table:
${cleanTermsList || "* [Automatically establish critical terms list if undefined]"}

5. **LESSON EXPOSITION SUMMARY**
   Draft a comprehensive teacher explanation summary (approx. 350 words) mapping directly to:
   "${summary}"
   Provide direct explanation points, structural flow instructions, and answers to common student misconceptions.`;

            if (hasHandout) {
                prompt += `\n\n6. **STUDENT HANDOUT (ADA & UDL COMPLIANT)**
   Create a highly accessible, print-ready, clean-contrast student handout. 
   * It must feature an 'Objective Summary' using simplified, big-concept language.
   * Format sections with clear, readable borders, structured bullet points, and blank spaces for student guided-notes.
   * Provide a practical, low-friction, hands-on classroom activity description that requires only standard materials.`;
            }

            if (hasQuiz) {
                prompt += `\n\n7. **"TEST YOUR KNOWLEDGE" FORMATIVE QUIZ**
   Build a formative knowledge check matching this format:
   * Total Questions: ${quizCount}
   * Question Style: ${quizType.replace('-', ' ')}
