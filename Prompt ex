        // Toggle Dark/Light Mode
        function initTheme() {
            const themeToggleBtn = document.getElementById('theme-toggle');
            const sunIcon = document.getElementById('theme-sun');
            const moonIcon = document.getElementById('theme-moon');

            // Apply system default or saved preference
            if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
                sunIcon.classList.remove('hidden');
                moonIcon.classList.add('hidden');
            } else {
                document.documentElement.classList.remove('dark');
                sunIcon.classList.add('hidden');
                moonIcon.classList.remove('hidden');
            }

            themeToggleBtn.addEventListener('click', () => {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                    sunIcon.classList.add('hidden');
                    moonIcon.classList.remove('hidden');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                    sunIcon.classList.remove('hidden');
                    moonIcon.classList.add('hidden');
                }
            });
        }

        // Accessibility Adjustments
        function initAccessibility() {
            let baseSizePercent = 100;
            const textDecrease = document.getElementById('btn-text-decrease');
            const textReset = document.getElementById('btn-text-reset');
            const textIncrease = document.getElementById('btn-text-increase');

            textDecrease.addEventListener('click', () => {
                if (baseSizePercent > 85) {
                    baseSizePercent -= 5;
                    document.documentElement.style.fontSize = `${baseSizePercent}%`;
                }
            });

            textReset.addEventListener('click', () => {
                baseSizePercent = 100;
                document.documentElement.style.fontSize = `100%`;
            });

            textIncrease.addEventListener('click', () => {
                if (baseSizePercent < 125) {
                    baseSizePercent += 5;
                    document.documentElement.style.fontSize = `${baseSizePercent}%`;
                }
            });
        }

        // Dynamic Input Mechanics: OBJECTIVES
        function renderObjectivesInputs() {
            const container = document.getElementById('objectives-container');
            container.innerHTML = '';
            
            objectives.forEach((obj, idx) => {
                const row = document.createElement('div');
                row.className = "flex items-center gap-2 group";
                row.innerHTML = `
                    <span class="text-xs text-slate-400 font-bold w-4">${idx + 1}.</span>
                    <input type="text" id="obj-input-${idx}" class="flex-grow bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-1.5 text-xs focus:ring-primary-500" value="${obj}" oninput="updateObjective(${idx}, this.value)" aria-label="Objective ${idx + 1}">
                    <button type="button" onclick="removeObjective(${idx})" class="p-1.5 text-slate-400 hover:text-accent-rose focus:text-accent-rose group-hover:opacity-100 transition" aria-label="Remove Objective ${idx + 1}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                    </button>
                `;
                container.appendChild(row);
            });
        }

        function addObjective() {
            if (objectives.length < 6) {
                objectives.push("");
                renderObjectivesInputs();
                document.getElementById(`obj-input-${objectives.length - 1}`).focus();
                generatePrompt();
            } else {
                showToast("Maximum of 6 learning objectives allowed.", "error");
            }
        }

        function updateObjective(idx, value) {
            objectives[idx] = value;
            generatePrompt();
        }

        function removeObjective(idx) {
            if (objectives.length > 1) {
                objectives.splice(idx, 1);
                renderObjectivesInputs();
                generatePrompt();
            } else {
                showToast("At least one objective is required.", "error");
            }
        }

        // Dynamic Input Mechanics: KEY TERMS
        function renderKeyTermsInputs() {
            const container = document.getElementById('key-terms-container');
            container.innerHTML = '';
            
            keyTerms.forEach((kt, idx) => {
                const row = document.createElement('div');
                row.className = "space-y-1 p-2 bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850 rounded-xl relative group";
                row.innerHTML = `
                    <div class="flex items-center gap-2">
                        <input type="text" id="term-name-${idx}" class="w-1/3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg px-2.5 py-1 text-xs font-bold" placeholder="Term" value="${kt.term}" oninput="updateKeyTerm(${idx}, 'term', this.value)" aria-label="Key concept word ${idx + 1}">
                        <input type="text" id="term-def-${idx}" class="flex-grow bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg px-2.5 py-1 text-xs" placeholder="Definition / core meaning" value="${kt.definition}" oninput="updateKeyTerm(${idx}, 'definition', this.value)" aria-label="Definition ${idx + 1}">
                        <button type="button" onclick="removeKeyTerm(${idx})" class="p-1 text-slate-400 hover:text-accent-rose group-hover:opacity-100 transition" aria-label="Remove Term ${idx + 1}">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                        </button>
                    </div>
                `;
                container.appendChild(row);
            });
        }

        function addKeyTerm() {
            if (keyTerms.length < 6) {
                keyTerms.push({ term: "", definition: "" });
                renderKeyTermsInputs();
                document.getElementById(`term-name-${keyTerms.length - 1}`).focus();
                generatePrompt();
            } else {
                showToast("Maximum of 6 vocabulary items supported.", "error");
            }
        }

        function updateKeyTerm(idx, field, value) {
            keyTerms[idx][field] = value;
            generatePrompt();
        }

        function removeKeyTerm(idx) {
            if (keyTerms.length > 1) {
                keyTerms.splice(idx, 1);
                renderKeyTermsInputs();
                generatePrompt();
