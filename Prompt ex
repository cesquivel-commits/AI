<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AuraPrompt | AI Lesson Plan & Resource Prompt Generator</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#f5f3ff',
                            100: '#ede9fe',
                            200: '#ddd6fe',
                            500: '#6366f1',
                            600: '#4f46e5',
                            700: '#4338ca',
                            900: '#312e81',
                        },
                        accent: {
                            emerald: '#10b981',
                            rose: '#f43f5e',
                            amber: '#f59e0b'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Custom scrollbar for premium feel */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        .dark ::-webkit-scrollbar-track {
            background: #1e293b;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .dark ::-webkit-scrollbar-thumb {
            background: #475569;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
        /* Custom focus rings for enhanced ADA navigation visibility */
        input:focus-visible, select:focus-visible, textarea:focus-visible, button:focus-visible {
            outline: 3px solid #6366f1 !important;
            outline-offset: 2px;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100 min-h-screen flex flex-col transition-colors duration-300">

    <!-- Screen Reader Skip Link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:p-4 focus:bg-primary-600 focus:text-white focus:rounded-lg focus:shadow-lg">
        Skip to main content
    </a>

    <!-- Top Navigation Header -->
    <header class="sticky top-0 z-40 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <!-- Logo Icon -->
                <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-primary-600 to-indigo-400 flex items-center justify-center text-white shadow-md shadow-primary-500/20">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-primary-600 to-indigo-500 bg-clip-text text-transparent">
                        AuraPrompt
                    </h1>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">AI Lesson Architect & Prompt Suite</p>
                </div>
            </div>

            <!-- Accessibility Controls & Theme Toggle -->
            <div class="flex items-center space-x-3">
                <!-- High Contrast/Text Size Controls for Accessibility -->
                <div class="hidden sm:flex items-center bg-slate-100 dark:bg-slate-800 rounded-lg p-1 space-x-1" role="group" aria-label="Accessibility settings">
                    <button id="btn-text-decrease" class="p-1.5 rounded text-slate-600 dark:text-slate-300 hover:bg-white dark:hover:bg-slate-700 transition" aria-label="Decrease text size">
                        <span class="text-xs font-bold" aria-hidden="true">A-</span>
                    </button>
                    <button id="btn-text-reset" class="px-2 py-1 rounded text-xs font-semibold text-slate-600 dark:text-slate-300 hover:bg-white dark:hover:bg-slate-700 transition" aria-label="Reset text size">
                        Reset
                    </button>
                    <button id="btn-text-increase" class="p-1.5 rounded text-slate-600 dark:text-slate-300 hover:bg-white dark:hover:bg-slate-700 transition" aria-label="Increase text size">
                        <span class="text-sm font-bold" aria-hidden="true">A+</span>
                    </button>
                </div>

                <!-- Theme Toggle Button -->
                <button id="theme-toggle" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800/80 transition-all focus:outline-none" aria-label="Toggle dark mode">
                    <!-- Sun Icon (for dark mode) -->
                    <svg id="theme-sun" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m2.828-9.9a5 5 0 117.071 7.071l-7.071-7.071z"></path>
                    </svg>
                    <!-- Moon Icon (for light mode) -->
                    <svg id="theme-moon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Workspace -->
    <main id="main-content" class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Welcome Banner & Quick Presets -->
        <section class="mb-8" aria-labelledby="welcome-heading">
            <div class="bg-gradient-to-r from-primary-900 to-indigo-950 rounded-2xl p-6 sm:p-8 text-white shadow-xl relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 w-48 h-48 rounded-full bg-indigo-500/10 blur-2xl"></div>
                <div class="relative z-10 max-w-3xl">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-primary-500/20 text-indigo-200 mb-4 border border-indigo-500/30">
                        ✨ ADA Compliant & Pedagogically Anchored
                    </span>
                    <h2 id="welcome-heading" class="text-2xl sm:text-3.5xl font-black tracking-tight mb-2">
                        Build Bulletproof Lesson Generation Prompts
                    </h2>
                    <p class="text-slate-300 text-sm sm:text-base mb-6 leading-relaxed">
                        Design comprehensive, standard-aligned lesson structures complete with differentiated student handouts, accessible formatting, and adaptive knowledge checks. Ready to run on any AI model.
                    </p>
                    
                    <!-- Presets Module -->
                    <div>
                        <h3 class="text-xs uppercase tracking-wider text-slate-400 font-bold mb-3">Load Instant Pedagogic Presets</h3>
                        <div class="flex flex-wrap gap-2" role="group" aria-label="Sample configurations">
                            <button onclick="loadPreset('photosynthesis')" class="px-3.5 py-1.5 bg-white/10 hover:bg-white/20 text-white rounded-lg text-xs font-semibold border border-white/10 transition-all focus:ring-2 focus:ring-white">
                                🌱 Science: Photosynthesis (Grade 7)
                            </button>
                            <button onclick="loadPreset('pythagorean')" class="px-3.5 py-1.5 bg-white/10 hover:bg-white/20 text-white rounded-lg text-xs font-semibold border border-white/10 transition-all focus:ring-2 focus:ring-white">
                                📐 Math: Pythagorean Theorem (Grade 8)
                            </button>
                            <button onclick="loadPreset('democracy')" class="px-3.5 py-1.5 bg-white/10 hover:bg-white/20 text-white rounded-lg text-xs font-semibold border border-white/10 transition-all focus:ring-2 focus:ring-white">
                                ⚖️ Civics: Principles of Democracy (Grade 10)
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dynamic Two-Column Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- LEFT COLUMN: Parameter Configuration Form (7/12 width) -->
            <section class="lg:col-span-5 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm p-6 space-y-6" aria-labelledby="generator-form-title">
                <div class="border-b border-slate-100 dark:border-slate-800/80 pb-4 flex items-center justify-between">
                    <h2 id="generator-form-title" class="text-lg font-bold flex items-center gap-2">
                        <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                        </svg>
                        Lesson Parameters
                    </h2>
                    <button onclick="resetForm()" class="text-xs text-slate-500 hover:text-accent-rose dark:text-slate-400 dark:hover:text-rose-400 font-semibold transition" aria-label="Reset form fields">
                        Clear All
                    </button>
                </div>

                <form id="prompt-architect-form" class="space-y-5" onsubmit="event.preventDefault();">
                    
                    <!-- Group 1: General Meta -->
                    <fieldset class="space-y-4">
                        <legend class="text-xs font-extrabold text-primary-500 uppercase tracking-widest">1. Foundation</legend>
                        
                        <div>
                            <label for="lesson-title" class="block text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-300 mb-1.5">Lesson Title</label>
                            <input type="text" id="lesson-title" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-sm transition-colors focus:ring-primary-500 focus:border-primary-500" placeholder="e.g., Photosynthesis & Plant Energy" required>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="lesson-subject" class="block text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-300 mb-1.5">Subject</label>
                                <input type="text" id="lesson-subject" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-sm transition-colors focus:ring-primary-500 focus:border-primary-500" placeholder="e.g., Biology" required>
                            </div>
                            <div>
                                <label for="lesson-grade" class="block text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-300 mb-1.5">Grade Level / Cohort</label>
                                <select id="lesson-grade" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-sm transition-colors focus:ring-primary-500 focus:border-primary-500">
                                    <option value="Kindergarten - Grade 2">K - Grade 2</option>
                                    <option value="Grade 3 - Grade 5">Grade 3 - 5</option>
                                    <option value="Grade 6 - Grade 8" selected>Grade 6 - 8 (Middle)</option>
                                    <option value="Grade 9 - Grade 12">Grade 9 - 12 (High)</option>
                                    <option value="Higher Education">Higher Education</option>
                                    <option value="Professional Development">Professional Training</option>
                                </select>
                            </div>
                        </div>
                    </fieldset>

                    <!-- Group 2: Learning Objectives (Dynamic) -->
                    <fieldset class="space-y-3">
                        <div class="flex items-center justify-between">
                            <legend class="text-xs font-extrabold text-primary-500 uppercase tracking-widest">2. Objectives (SMART)</legend>
                            <button type="button" onclick="addObjective()" class="text-xs text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 font-bold flex items-center gap-1" aria-label="Add learning objective">
                                <span aria-hidden="true">+</span> Add Objective
                            </button>
                        </div>
                        <div id="objectives-container" class="space-y-2.5">
                            <!-- Dynamically injected objective inputs go here -->
                        </div>
                    </fieldset>

                    <!-- Group 3: Vocab / Key Terms (Dynamic) -->
                    <fieldset class="space-y-3">
                        <div class="flex items-center justify-between">
                            <legend class="text-xs font-extrabold text-primary-500 uppercase tracking-widest">3. Vocabulary & Concepts</legend>
                            <button type="button" onclick="addKeyTerm()" class="text-xs text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 font-bold flex items-center gap-1" aria-label="Add dynamic key term">
                                <span aria-hidden="true">+</span> Add Term
                            </button>
                        </div>
                        <div id="key-terms-container" class="space-y-2.5">
                            <!-- Dynamically injected vocabulary elements go here -->
                        </div>
                    </fieldset>

                    <!-- Group 4: Structuring Pedagogy -->
                    <fieldset class="space-y-4">
                        <legend class="text-xs font-extrabold text-primary-500 uppercase tracking-widest">4. Pedagogical Preferences</legend>
                        
                        <div>
                            <label for="analogy-preference" class="block text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-300 mb-1.5">Analogies & Real-World Framing</label>
                            <select id="analogy-preference" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-sm transition-colors focus:ring-primary-500 focus:border-primary-500">
                                <option value="highly-relatable">Highly relatable daily life examples (highly active visualizer)</option>
                                <option value="scientific-technical">Industrial, engineering or scientific case studies</option>
                                <option value="historical-narrative">Historical and storytelling narratives</option>
                                <option value="minimalist">Direct and minimalist definition-first explanation</option>
                            </select>
                        </div>

                        <div>
                            <label for="lesson-summary" class="block text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-300 mb-1.5">Context / Core Focus of Summary</label>
                            <textarea id="lesson-summary" rows="2" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-sm transition-colors focus:ring-primary-500 focus:border-primary-500 resize-none" placeholder="e.g., Focus specifically on the light-dependent cycle and how chloroplasts convert photons..."></textarea>
                        </div>
                    </fieldset>

                    <!-- Group 5: Assessment & Student Materials -->
                    <fieldset class="space-y-4 pt-2">
                        <legend class="text-xs font-extrabold text-primary-500 uppercase tracking-widest">5. Assessment & Accessibility</legend>
                        
                        <!-- Toggle for Handout -->
                        <div class="flex items-start justify-between bg-slate-50 dark:bg-slate-950 p-3 rounded-xl border border-slate-150 dark:border-slate-850">
                            <div class="flex items-start space-x-3">
                                <div class="pt-0.5">
                                    <input type="checkbox" id="generate-handout" class="w-4 h-4 text-primary-600 border-slate-300 rounded focus:ring-primary-500" checked>
                                </div>
                                <div>
                                    <label for="generate-handout" class="block text-xs font-bold uppercase tracking-wide text-slate-700 dark:text-slate-200">Include Differentiated Handout</label>
                                    <p class="text-slate-500 dark:text-slate-400 text-[11px] leading-tight mt-0.5">Prompt the AI to construct a high-accessibility structural handout for student use.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Toggle for Quiz -->
                        <div class="flex flex-col bg-slate-50 dark:bg-slate-950 p-3 rounded-xl border border-slate-150 dark:border-slate-850 space-y-3">
                            <div class="flex items-start justify-between">
                                <div class="flex items-start space-x-3">
                                    <div class="pt-0.5">
                                        <input type="checkbox" id="generate-quiz" class="w-4 h-4 text-primary-600 border-slate-300 rounded focus:ring-primary-500" checked onchange="toggleQuizSettings()">
                                    </div>
                                    <div>
                                        <label for="generate-quiz" class="block text-xs font-bold uppercase tracking-wide text-slate-700 dark:text-slate-200">Include "Test Your Knowledge" Quiz</label>
                                        <p class="text-slate-500 dark:text-slate-400 text-[11px] leading-tight mt-0.5">Prompt the AI to produce formative assessment materials.</p>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Sub Quiz Parameters (Show/Hide dynamically) -->
                            <div id="quiz-meta-panel" class="grid grid-cols-2 gap-3 pl-7 transition-all duration-250">
                                <div>
                                    <label for="quiz-count" class="block text-[10px] font-extrabold uppercase tracking-widest text-slate-500 mb-1">Question Count</label>
                                    <select id="quiz-count" class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg px-2 py-1 text-xs transition">
                                        <option value="3">3 Questions</option>
                                        <option value="5" selected>5 Questions</option>
                                        <option value="10">10 Questions</option>
                                    </select>
                                </div>
                                <div>
                                    <label for="quiz-type" class="block text-[10px] font-extrabold uppercase tracking-widest text-slate-500 mb-1">Question Style</label>
                                    <select id="quiz-type" class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg px-2 py-1 text-xs transition">
                                        <option value="multiple-choice">Multiple Choice (MCQ)</option>
                                        <option value="mixed">Mixed (MCQ, Fill, Essay)</option>
                                        <option value="analytical">Scenario-based Analytical</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- ADA / Universal Design for Learning (UDL) Checkbox -->
                        <div class="flex items-start space-x-3 bg-slate-50 dark:bg-slate-950 p-3 rounded-xl border border-slate-150 dark:border-slate-850">
                            <div class="pt-0.5">
                                <input type="checkbox" id="ada-compliant" class="w-4 h-4 text-primary-600 border-slate-300 rounded focus:ring-primary-500" checked disabled>
                            </div>
                            <div>
                                <label for="ada-compliant" class="block text-xs font-bold uppercase tracking-wide text-slate-700 dark:text-slate-200 flex items-center gap-1.5">
                                    Enforce ADA / UDL Standards
                                    <span class="px-1.5 py-0.2 bg-primary-100 text-primary-700 dark:bg-primary-900/40 dark:text-primary-300 rounded text-[9px] font-extrabold">Auto-On</span>
                                </label>
                                <p class="text-slate-500 dark:text-slate-400 text-[11px] leading-tight mt-0.5">Enforces descriptive header hierarchies, clear layout indicators, screen-reader friendly formatting instructions, and cognitive support structures.</p>
                            </div>
                        </div>
                    </fieldset>
                </form>
            </section>

            <!-- RIGHT COLUMN: Output Preview & Simulated sandbox (7/12 width) -->
            <section class="lg:col-span-7 space-y-6" aria-labelledby="output-workspace-title">
                <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                    
                    <!-- Tab Headers (ADA Tablist Role Included) -->
                    <div class="bg-slate-50 dark:bg-slate-900/60 border-b border-slate-150 dark:border-slate-800 p-2" role="tablist" aria-label="Output views">
                        <div class="flex flex-wrap gap-1">
                            <button id="tab-prompt" onclick="switchTab('prompt')" class="px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all focus:outline-none flex items-center gap-2 bg-white dark:bg-slate-800 shadow-sm text-primary-600 dark:text-white" role="tab" aria-selected="true" aria-controls="panel-prompt">
                                <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                Engineered Prompt
                            </button>
                            <button id="tab-preview" onclick="switchTab('preview')" class="px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all focus:outline-none flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800" role="tab" aria-selected="false" aria-controls="panel-preview">
                                <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                                Sandbox Simulation
                            </button>
                        </div>
                    </div>

                    <!-- Panel A: Real Generated Prompt -->
                    <div id="panel-prompt" class="p-6 space-y-4 block" role="tabpanel" aria-labelledby="tab-prompt">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3 id="output-workspace-title" class="text-sm font-bold text-slate-800 dark:text-slate-200">
                                    Ready-to-Paste Structural Prompt
                                </h3>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Optimized for Gemini, ChatGPT, Claude, and school AI platforms.</p>
                            </div>
                            <!-- Copy Button -->
                            <button id="btn-copy" onclick="copyPromptToClipboard()" class="bg-primary-600 hover:bg-primary-700 text-white font-bold text-xs px-4 py-2.5 rounded-xl shadow-md shadow-primary-500/10 flex items-center gap-1.5 transition-all focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                                </svg>
                                Copy Prompt
                            </button>
                        </div>

                        <!-- Rendered Textarea (Selectable and readable) -->
                        <div class="relative">
                            <textarea id="prompt-output" readonly class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl p-4 text-[13px] font-mono leading-relaxed h-[480px] focus:ring-2 focus:ring-primary-500 focus:outline-none resize-none" aria-label="Engineered lesson plan prompt output"></textarea>
                        </div>
                    </div>

                    <!-- Panel B: Simulated Mock Lesson Plan & Output sandbox -->
                    <div id="panel-preview" class="p-6 space-y-6 hidden" role="tabpanel" aria-labelledby="tab-preview">
                        <div class="border-b border-slate-100 dark:border-slate-800/60 pb-4">
